[user]
    name = Karim Elmirou
    email = k@elmirou.com

[init]
    defaultBranch = main

[pull]
    rebase = false

[fetch]
    prune = true

[rerere]
    enabled = true

[merge]
    conflictstyle = zdiff3

[log]
    date = format-local:%d-%m-%Y %H:%M:%S %z

[core]
    excludesfile = ~/.gitignore_global

[include]
    path = ~/.gitconfig.local

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
