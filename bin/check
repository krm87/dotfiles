#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

info() {
  printf "[check] %s\n" "$1"
}

warn() {
  printf "[check] warning: %s\n" "$1" >&2
}

info "checking bash syntax"
bash -n "$ROOT/install.sh" "$ROOT/bin/check" "$ROOT/bin/doctor"
sh -n "$ROOT/bin/tmux-copy"

if command -v shellcheck >/dev/null 2>&1; then
  info "running shellcheck"
  shellcheck "$ROOT/install.sh" "$ROOT/bin/check" "$ROOT/bin/doctor" "$ROOT/bin/tmux-copy"
else
  warn "shellcheck not found; skipping"
fi

if command -v zsh >/dev/null 2>&1; then
  info "checking zsh syntax"
  zsh -n \
    "$ROOT/zsh/.zshrc" \
    "$ROOT/zsh/aliases.zsh" \
    "$ROOT/zsh/exports.zsh" \
    "$ROOT/zsh/functions.zsh" \
    "$ROOT/zsh/local.example.zsh" \
    "$ROOT/zsh/plugins.zsh" \
    "$ROOT/zsh/zinit.zsh"
else
  warn "zsh not found; skipping zsh syntax checks"
fi

info "checking git config syntax"
git config --file "$ROOT/git/gitconfig" --includes --list >/dev/null

ghostty_bin=""
if command -v ghostty >/dev/null 2>&1; then
  ghostty_bin="$(command -v ghostty)"
elif [ -x /Applications/Ghostty.app/Contents/MacOS/ghostty ]; then
  ghostty_bin="/Applications/Ghostty.app/Contents/MacOS/ghostty"
fi

if [ -n "$ghostty_bin" ]; then
  info "checking Ghostty config syntax"
  if ! ghostty_output="$("$ghostty_bin" +validate-config --config-file="$ROOT/ghostty/config" 2>&1)"; then
    printf "%s\n" "$ghostty_output" >&2
    exit 1
  fi
else
  warn "ghostty not found; skipping Ghostty config check"
fi

if command -v tmux >/dev/null 2>&1; then
  info "checking tmux config syntax"
  tmux_tmp="$(mktemp -d)"
  tmux_socket="$tmux_tmp/tmux.sock"
  tmux_output=""
  tmux_status=0
  tmux_output="$(
    {
      tmux -S "$tmux_socket" -f "$ROOT/tmux/tmux.conf" new-session -d -s dotfiles-check &&
        tmux -S "$tmux_socket" source-file -n "$ROOT/tmux/tmux.conf" &&
        tmux -S "$tmux_socket" kill-server
    } 2>&1
  )" || tmux_status=$?
  tmux -S "$tmux_socket" kill-server >/dev/null 2>&1 || true
  rm -rf "$tmux_tmp"

  if [ "$tmux_status" -ne 0 ] || [ -n "$tmux_output" ]; then
    if printf "%s\n" "$tmux_output" | grep -Fq "Operation not permitted"; then
      warn "tmux socket creation is blocked; skipping tmux config check"
    else
      printf "%s\n" "$tmux_output" >&2
      exit 1
    fi
  fi
else
  warn "tmux not found; skipping tmux config check"
fi

if command -v apparmor_parser >/dev/null 2>&1; then
  info "checking AppArmor profile template"
  codex_attachment='@{HOME}/{.local/bin/codex,.codex/packages/standalone/{current,releases/*}/bin/codex}'
  tmp_profile="$(mktemp)"
  while IFS= read -r line || [ -n "$line" ]; do
    printf "%s\n" "${line/__CODEX_APPARMOR_ATTACHMENT__/$codex_attachment}"
  done <"$ROOT/apparmor/codex.template" >"$tmp_profile"
  apparmor_parser -Q -K "$tmp_profile"
  rm -f "$tmp_profile"
else
  warn "apparmor_parser not found; skipping AppArmor template check"
fi

info "checking package manifests"
test -s "$ROOT/apparmor/codex.template"
test -s "$ROOT/ghostty/config"
test -s "$ROOT/packages/macos/Brewfile"
test -s "$ROOT/packages/ubuntu/apt.txt"
test -s "$ROOT/packages/go/global.txt"
test -s "$ROOT/packages/npm/global.txt"
test -s "$ROOT/packages/npm/allow-scripts.txt"
test -x "$ROOT/bin/doctor"
test -x "$ROOT/bin/tmux-copy"

info "ok"
