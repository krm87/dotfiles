#!/usr/bin/env bash
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OS="$(uname -s)"

PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0
INFO_COUNT=0
SKIP_COUNT=0

if [ -t 1 ]; then
  COLOR_OK="$(printf '\033[1;32m')"
  COLOR_WARN="$(printf '\033[1;33m')"
  COLOR_FAIL="$(printf '\033[1;31m')"
  COLOR_INFO="$(printf '\033[1;34m')"
  COLOR_RESET="$(printf '\033[0m')"
else
  COLOR_OK=""
  COLOR_WARN=""
  COLOR_FAIL=""
  COLOR_INFO=""
  COLOR_RESET=""
fi

section() {
  printf "\n%s\n" "$1"
}

emit() {
  local status="$1"
  local label="$2"
  local detail="${3:-}"
  local color="$COLOR_INFO"

  case "$status" in
    OK)
      color="$COLOR_OK"
      ;;
    WARN)
      color="$COLOR_WARN"
      ;;
    FAIL)
      color="$COLOR_FAIL"
      ;;
    INFO | SKIP)
      color="$COLOR_INFO"
      ;;
  esac

  if [ -n "$detail" ]; then
    printf "%b%-4s%b %s - %s\n" "$color" "$status" "$COLOR_RESET" "$label" "$detail"
  else
    printf "%b%-4s%b %s\n" "$color" "$status" "$COLOR_RESET" "$label"
  fi
}

ok() {
  PASS_COUNT=$((PASS_COUNT + 1))
  emit "OK" "$1" "${2:-}"
}

warning() {
  WARN_COUNT=$((WARN_COUNT + 1))
  emit "WARN" "$1" "${2:-}"
}

failure() {
  FAIL_COUNT=$((FAIL_COUNT + 1))
  emit "FAIL" "$1" "${2:-}"
}

note() {
  INFO_COUNT=$((INFO_COUNT + 1))
  emit "INFO" "$1" "${2:-}"
}

skip() {
  SKIP_COUNT=$((SKIP_COUNT + 1))
  emit "SKIP" "$1" "${2:-}"
}

capture_first_line() {
  local output
  local status

  output="$("$@" 2>&1)"
  status=$?
  if [ "$status" -ne 0 ]; then
    return "$status"
  fi

  printf "%s\n" "$output" |
    sed -n '/^[[:space:]]*$/d; /^WARNING[[:space:]:]/d; p; q'
}

tool_version() {
  local cmd="$1"

  case "$cmd" in
    git-lfs | gopls)
      capture_first_line "$cmd" version || true
      ;;
    go)
      capture_first_line "$cmd" version || true
      ;;
    tmux)
      capture_first_line "$cmd" -V || true
      ;;
    dot)
      capture_first_line "$cmd" -V || true
      ;;
    hcloud)
      capture_first_line "$cmd" version || true
      ;;
    dagger)
      capture_first_line "$cmd" version || true
      ;;
    plantuml)
      capture_first_line "$cmd" -version || true
      ;;
    ansible)
      ANSIBLE_LOCAL_TEMP="${TMPDIR:-/tmp}/ansible-local" capture_first_line "$cmd" --version || true
      ;;
    az)
      AZURE_CONFIG_DIR="${TMPDIR:-/tmp}/azure-cli" capture_first_line "$cmd" --version || true
      ;;
    python3)
      capture_first_line "$cmd" --version || true
      ;;
    *)
      capture_first_line "$cmd" --version || true
      ;;
  esac
}

check_tool() {
  local label="$1"
  local severity="$2"
  local candidate
  local path
  local version
  shift 2

  for candidate in "$@"; do
    path="$(command -v "$candidate" 2>/dev/null || true)"
    if [ -n "$path" ]; then
      if ! version="$(tool_version "$candidate")"; then
        version=""
      fi
      if [ -n "$version" ]; then
        ok "$label" "$version ($path)"
      else
        ok "$label" "$path"
      fi
      return 0
    fi
  done

  case "$severity" in
    fail)
      failure "$label" "missing command: $*"
      ;;
    warn)
      warning "$label" "missing command: $*"
      ;;
    *)
      note "$label" "missing command: $*"
      ;;
  esac
}

check_ghostty() {
  local app="/Applications/Ghostty.app"
  local path
  local version

  path="$(command -v ghostty 2>/dev/null || true)"
  if [ -n "$path" ]; then
    version="$(tool_version ghostty)"
    if [ -n "$version" ]; then
      ok "Ghostty" "$version ($path)"
    else
      ok "Ghostty" "$path"
    fi
  elif [ -d "$app" ]; then
    ok "Ghostty" "$app"
  else
    warning "Ghostty" "missing command or app bundle"
  fi
}

path_index() {
  local needle="$1"
  local dir
  local index=0
  local old_ifs="$IFS"
  local path_value="${PATH:-}"

  IFS=:
  for dir in $path_value; do
    if [ "$dir" = "$needle" ]; then
      IFS="$old_ifs"
      printf "%s\n" "$index"
      return 0
    fi
    index=$((index + 1))
  done
  IFS="$old_ifs"

  return 1
}

check_path_contains() {
  local label="$1"
  local dir="$2"

  if path_index "$dir" >/dev/null; then
    ok "$label" "$dir is in PATH"
  else
    warning "$label" "$dir is not in current PATH"
  fi
}

check_path_before() {
  local label="$1"
  local first="$2"
  local second="$3"
  local first_index
  local second_index

  if ! first_index="$(path_index "$first")"; then
    warning "$label" "$first is not in current PATH"
    return 0
  fi

  if ! second_index="$(path_index "$second")"; then
    skip "$label" "$second is not in current PATH"
    return 0
  fi

  if [ "$first_index" -lt "$second_index" ]; then
    ok "$label" "$first comes before $second"
  else
    warning "$label" "$first should come before $second"
  fi
}

check_expected_symlink() {
  local label="$1"
  local target="$2"
  local source="$3"
  local actual

  if [ -L "$target" ]; then
    actual="$(readlink "$target" || true)"
    if [ ! -e "$target" ]; then
      failure "$label" "$target is a broken symlink to $actual"
    elif [ "$actual" = "$source" ]; then
      ok "$label" "$target -> $source"
    else
      warning "$label" "$target points to $actual, expected $source"
    fi
  elif [ -e "$target" ]; then
    warning "$label" "$target exists but is not a symlink"
  else
    failure "$label" "$target is missing"
  fi
}

check_file_readable() {
  local label="$1"
  local file="$2"
  local severity="$3"

  if [ -r "$file" ]; then
    ok "$label" "$file is readable"
    return 0
  fi

  if [ "$severity" = "fail" ]; then
    failure "$label" "$file is missing or unreadable"
  else
    warning "$label" "$file is missing or unreadable"
  fi
}

check_local_override() {
  local label="$1"
  local file="$2"

  if [ -r "$file" ]; then
    note "$label" "present: $file"
  elif [ -e "$file" ]; then
    warning "$label" "exists but is not readable: $file"
  else
    note "$label" "absent: $file"
  fi
}

check_package_manager() {
  local version

  section "Package Manager"

  case "$OS" in
    Darwin)
      if command -v brew >/dev/null 2>&1; then
        version="$(capture_first_line brew --version || true)"
        ok "Homebrew" "$version ($(command -v brew))"
      else
        failure "Homebrew" "brew is required on macOS"
      fi
      ;;
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        version="$(capture_first_line apt-get --version || true)"
        ok "apt" "$version ($(command -v apt-get))"
      else
        failure "apt" "apt-get is required on Ubuntu-style Linux"
      fi

      if command -v brew >/dev/null 2>&1; then
        version="$(capture_first_line brew --version || true)"
        note "Linuxbrew" "$version ($(command -v brew))"
      else
        note "Linuxbrew" "not installed"
      fi
      ;;
    *)
      failure "OS" "unsupported system: $OS"
      ;;
  esac
}

check_tools() {
  section "Tool Versions"

  check_tool "zsh" fail zsh
  check_tool "git" fail git
  check_tool "git-lfs" fail git-lfs
  check_tool "curl" fail curl
  check_tool "fzf" fail fzf
  check_tool "direnv" fail direnv
  check_tool "zoxide" fail zoxide
  check_tool "ripgrep" fail rg
  check_tool "fd" fail fd fdfind
  check_tool "bat" fail bat batcat
  check_tool "eza" fail eza
  check_tool "tmux" fail tmux
  check_tool "shellcheck" fail shellcheck
  check_tool "jq" fail jq
  check_tool "yq" fail yq
  check_tool "starship" fail starship
  check_tool "Go" fail go
  check_tool "gopls" warn gopls
  check_tool "Node" warn node
  check_tool "npm" warn npm
  check_tool "Atuin" warn atuin
  check_tool "Claude Code" warn claude
  check_tool "Codex" warn codex

  case "$OS" in
    Darwin)
      check_tool "GitHub CLI" warn gh
      check_tool "uv" warn uv
      check_tool "Ansible" warn ansible
      check_tool "Azure CLI" warn az
      check_tool "Dagger" warn dagger
      check_tool "Hetzner Cloud CLI" warn hcloud
      check_tool "Trivy" warn trivy
      check_tool "Graphviz" warn dot
      check_tool "Pandoc" warn pandoc
      check_tool "PlantUML" warn plantuml
      check_tool "1Password CLI" warn op
      check_tool "dotnet" warn dotnet
      check_tool "OpenCode" warn opencode
      check_ghostty
      ;;
    Linux)
      check_tool "Python" fail python3
      check_tool "bubblewrap" fail bwrap
      check_tool "AppArmor parser" warn apparmor_parser
      ;;
  esac
}

check_path() {
  section "PATH"

  check_path_contains "user bin" "$HOME/bin"
  check_path_contains "user local bin" "$HOME/.local/bin"
  check_path_contains "Atuin bin" "$HOME/.atuin/bin"
  check_path_contains "Go bin" "$HOME/go/bin"
  check_path_contains "dotnet tools" "$HOME/.dotnet/tools"
  check_path_before "user tools before system" "$HOME/.local/bin" "/usr/bin"

  case "$OS" in
    Darwin)
      if [ -x /opt/homebrew/bin/brew ]; then
        check_path_contains "Homebrew bin" "/opt/homebrew/bin"
        check_path_before "Homebrew before system" "/opt/homebrew/bin" "/usr/bin"
      else
        skip "Homebrew PATH" "/opt/homebrew/bin/brew not found"
      fi
      ;;
    Linux)
      if [ -d /usr/local/go/bin ]; then
        check_path_contains "Go root bin" "/usr/local/go/bin"
        check_path_before "Go root before system" "/usr/local/go/bin" "/usr/bin"
      else
        skip "Go root PATH" "/usr/local/go/bin not found"
      fi

      if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
        check_path_contains "Linuxbrew bin" "/home/linuxbrew/.linuxbrew/bin"
        check_path_before "Linuxbrew before system" "/home/linuxbrew/.linuxbrew/bin" "/usr/bin"
      fi
      ;;
  esac
}

check_symlinks() {
  section "Managed Files"

  check_expected_symlink "zshrc" "$HOME/.zshrc" "$ROOT/zsh/.zshrc"
  check_expected_symlink "starship" "$HOME/.config/starship.toml" "$ROOT/starship/starship.toml"
  check_expected_symlink "gitconfig" "$HOME/.gitconfig" "$ROOT/git/gitconfig"
  check_expected_symlink "gitignore" "$HOME/.gitignore_global" "$ROOT/git/gitignore_global"
  check_expected_symlink "tmux" "$HOME/.tmux.conf" "$ROOT/tmux/tmux.conf"

  check_file_readable "ssh config" "$HOME/.ssh/config" warn
  if [ -r "$HOME/.ssh/config" ]; then
    if grep -Eq '^[[:space:]]*Include[[:space:]]+~/.ssh/config.local' "$HOME/.ssh/config"; then
      ok "ssh local include" "$HOME/.ssh/config includes $HOME/.ssh/config.local"
    else
      warning "ssh local include" "$HOME/.ssh/config does not include $HOME/.ssh/config.local"
    fi
  fi
}

check_go() {
  local goroot

  section "Go"

  if ! command -v go >/dev/null 2>&1; then
    failure "Go version" "go is not installed"
    return 0
  fi

  ok "Go version" "$(go version)"

  goroot="$(go env GOROOT 2>/dev/null || true)"
  if [ -n "$goroot" ]; then
    ok "GOROOT" "$goroot"
  else
    warning "GOROOT" "go env GOROOT returned no value"
  fi

  if [ "$OS" = "Linux" ] && [ "$goroot" != "/usr/local/go" ]; then
    warning "Linux Go install" "expected /usr/local/go from install.sh, got ${goroot:-unknown}"
  fi

  check_path_contains "GOPATH bin" "$HOME/go/bin"
}

check_atuin() {
  local atuin_path
  local local_atuin="$HOME/.atuin/bin/atuin"
  local atuin_hook=". \"\$HOME/.atuin/bin/env\""
  local atuin_source_hook="source \"\$HOME/.atuin/bin/env\""
  local profile
  local found_hook=0

  section "Atuin"

  atuin_path="$(command -v atuin 2>/dev/null || true)"
  if [ -z "$atuin_path" ]; then
    warning "Atuin command" "atuin is not installed or not in PATH"
  else
    ok "Atuin command" "$atuin_path"
  fi

  if [ "$OS" = "Linux" ]; then
    if [ "$atuin_path" = "$local_atuin" ]; then
      ok "Atuin installer path" "$local_atuin is active"
    elif [ -x "$local_atuin" ]; then
      warning "Atuin installer path" "PATH resolves $atuin_path before $local_atuin"
    else
      warning "Atuin installer path" "$local_atuin is missing"
    fi
  fi

  check_path_contains "Atuin PATH" "$HOME/.atuin/bin"

  for profile in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    [ -r "$profile" ] || continue
    if grep -Fq "$atuin_hook" "$profile" ||
      grep -Fq "$atuin_source_hook" "$profile"; then
      found_hook=1
      warning "Atuin profile hook" "$profile still contains an installer PATH hook"
    fi
  done

  if [ "$found_hook" -eq 0 ]; then
    ok "Atuin profile hook" "no generated PATH hook found in shell profiles"
  fi
}

check_ssh_agent() {
  local onepassword_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

  section "SSH Agent"

  if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    warning "SSH_AUTH_SOCK" "not set"
  elif [ -S "$SSH_AUTH_SOCK" ]; then
    ok "SSH_AUTH_SOCK" "$SSH_AUTH_SOCK"
  else
    failure "SSH_AUTH_SOCK" "$SSH_AUTH_SOCK is not a socket"
  fi

  if [ "$OS" = "Darwin" ]; then
    if [ -S "$onepassword_sock" ]; then
      ok "1Password SSH agent" "$onepassword_sock"
    else
      warning "1Password SSH agent" "$onepassword_sock is not available"
    fi
  fi

  if command -v ssh-add >/dev/null 2>&1 && [ -S "${SSH_AUTH_SOCK:-}" ]; then
    if ssh-add -l >/dev/null 2>&1; then
      ok "ssh-add" "agent has at least one identity"
    else
      note "ssh-add" "agent is reachable but no identities were listed"
    fi
  fi
}

check_tmux() {
  local expected_default_shell="set-option -g default-shell \"\$SHELL\""
  local live_shell

  section "tmux"

  if ! command -v tmux >/dev/null 2>&1; then
    failure "tmux command" "tmux is not installed"
    return 0
  fi

  ok "tmux command" "$(tmux -V)"

  if [ -n "${SHELL:-}" ] && [ -x "$SHELL" ]; then
    ok "login shell" "$SHELL"
  else
    warning "login shell" "SHELL is unset or not executable: ${SHELL:-unset}"
  fi

  case "${SHELL:-}" in
    */zsh)
      ok "tmux shell" "tmux config inherits zsh from SHELL"
      ;;
    *)
      warning "tmux shell" "tmux config inherits SHELL, currently ${SHELL:-unset}"
      ;;
  esac

  if grep -Fq "$expected_default_shell" "$ROOT/tmux/tmux.conf"; then
    ok "tmux default-shell config" "uses current SHELL"
  else
    warning "tmux default-shell config" "tmux/tmux.conf no longer sets default-shell from SHELL"
  fi

  if [ -n "${TMUX:-}" ]; then
    live_shell="$(tmux show-options -gqv default-shell 2>/dev/null || true)"
    if [ -n "$live_shell" ]; then
      note "live tmux default-shell" "$live_shell"
    else
      warning "live tmux default-shell" "could not read tmux server option"
    fi
  fi
}

check_apparmor() {
  local enabled

  section "AppArmor"

  if [ "$OS" != "Linux" ]; then
    skip "AppArmor" "only applies on Linux"
    return 0
  fi

  if [ -r /sys/module/apparmor/parameters/enabled ]; then
    enabled="$(sed -n '1p' /sys/module/apparmor/parameters/enabled)"
    if [ "$enabled" = "Y" ]; then
      ok "AppArmor kernel module" "enabled"
    else
      warning "AppArmor kernel module" "reported $enabled"
    fi
  else
    warning "AppArmor kernel module" "status file is unavailable"
  fi

  if command -v apparmor_parser >/dev/null 2>&1; then
    ok "apparmor_parser" "$(command -v apparmor_parser)"
  else
    warning "apparmor_parser" "not installed"
  fi

  if [ -f /etc/apparmor.d/codex ]; then
    ok "Codex AppArmor profile" "/etc/apparmor.d/codex exists"
  else
    note "Codex AppArmor profile" "not installed; run ./install.sh --enable-codex-sandbox if needed"
  fi

  if [ -f /etc/sysctl.d/99-codex-sandbox.conf ]; then
    warning "legacy Codex sysctl" "/etc/sysctl.d/99-codex-sandbox.conf still exists"
  else
    ok "legacy Codex sysctl" "not present"
  fi
}

check_local_overrides() {
  section "Local Overrides"

  check_local_override "zsh local override" "$HOME/.config/dotfiles/local.zsh"
  check_local_override "git local override" "$HOME/.gitconfig.local"
  check_local_override "ssh local override" "$HOME/.ssh/config.local"
}

main() {
  printf "Dotfiles doctor: %s on %s\n" "$ROOT" "$OS"

  check_package_manager
  check_tools
  check_path
  check_symlinks
  check_go
  check_atuin
  check_ssh_agent
  check_tmux
  check_apparmor
  check_local_overrides

  section "Summary"
  printf "OK=%s WARN=%s FAIL=%s INFO=%s SKIP=%s\n" \
    "$PASS_COUNT" "$WARN_COUNT" "$FAIL_COUNT" "$INFO_COUNT" "$SKIP_COUNT"

  if [ "$FAIL_COUNT" -gt 0 ]; then
    exit 1
  fi
}

main "$@"
